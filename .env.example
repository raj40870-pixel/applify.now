MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/AppifyNow
JWT_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=https://appify-now.com.in
# Comma-separated list of allowed origins for API CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost

# Frontend API endpoint for production/APK builds.
# Keep empty in local web dev to use same-origin backend.
VITE_API_BASE_URL=https://appify-now.com.in


